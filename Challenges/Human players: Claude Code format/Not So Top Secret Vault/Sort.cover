    1: def insertion_sort(arr):
 2000:   for k in range(1,len(arr)):
 1999:     cur = arr[k]
 1999:     j = k
 1999:     while j>0 and arr[j-1] > cur:
             arr[j] = arr[j-1]
             j = j-1
 1999:     arr[j] = cur
       
    1: def selection_sort(arr):
 2001:   for k in range(0, len(arr)):
 2000:     minloc = k
 2000:     j = k + 1
2001000:     while j < len(arr):
1999000:       if arr[j] < arr[minloc]:
               minloc = j
1999000:       j = j + 1
 2000:     a = arr[k]
 2000:     b = arr[minloc]
 2000:     c = a
 2000:     arr[k] = b
 2000:     arr[minloc] = c
           
       
             
       
       
